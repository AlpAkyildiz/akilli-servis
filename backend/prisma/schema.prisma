generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DRIVER
  PARENT
}

enum StudentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VehicleStatus {
  IDLE
  ON_WAY
  MAINTENANCE
}

enum NotificationStatus {
  UNREAD
  READ
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(PARENT)
  name      String

  // Inheritance / Profiles (1-to-1)
  parentProfile ParentProfile?
  driverProfile DriverProfile?

  // Relations
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentProfile {
  id        Int      @id @default(autoincrement())
  phone     String?
  address   String?
  
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  children  Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DriverProfile {
  id            Int      @id @default(autoincrement())
  licenseNumber String?  @unique
  phone         String?
  
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  routes        Route[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Student {
  id           Int           @id @default(autoincrement())
  name         String
  schoolName   String
  schoolNumber String
  photoUrl     String?
  status       StudentStatus @default(PENDING)

  parentId     Int
  parent       ParentProfile @relation(fields: [parentId], references: [id])
  
  vehicleId    Int?
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id])

  boardingLogs BoardingLog[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Vehicle {
  id           Int           @id @default(autoincrement())
  licensePlate String        @unique
  capacity     Int
  model        String?
  status       VehicleStatus @default(IDLE)

  routes       Route[]
  students     Student[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Route {
  id          Int      @id @default(autoincrement())
  name        String
  startPoint  String?
  endPoint    String?
  
  driverId    Int
  driver      DriverProfile @relation(fields: [driverId], references: [id])
  
  vehicleId   Int
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id])

  stops       Stop[]
  boardingLogs BoardingLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stop {
  id          Int      @id @default(autoincrement())
  name        String
  lat         Float
  lng         Float

  routeId     Int
  route       Route    @relation(fields: [routeId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum BoardingType {
  BOARDED
  DROPPED_OFF
  ABSENT
}

model BoardingLog {
  id              Int          @id @default(autoincrement())
  type            BoardingType
  tripSessionId   String?      // UUID for a single trip session
  
  studentId Int
  student   Student      @relation(fields: [studentId], references: [id])
  
  routeId   Int?
  route     Route?       @relation(fields: [routeId], references: [id])

  driverProfileId Int?
  
  timestamp DateTime     @default(now())
}

model Notification {
  id        Int                @id @default(autoincrement())
  message   String
  status    NotificationStatus @default(UNREAD)

  userId    Int
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime           @default(now())
}
